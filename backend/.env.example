# ═══════════════════════════════════════════════
#  CREATOKITE — Environment Variables
#  Copy this to .env and fill ALL values
# ═══════════════════════════════════════════════

PORT=5000
NODE_ENV=development   # change to: production

# ── MongoDB Atlas ─────────────────────────────
# Atlas > Connect > Drivers > Copy SRV string
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/creatokite?retryWrites=true&w=majority&appName=Cluster0

# ── JWT (generate random 64-char strings) ─────
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Cookie ────────────────────────────────────
COOKIE_SECRET=CHANGE_THIS_TO_YET_ANOTHER_RANDOM_STRING

# ── Frontend URL (NO trailing slash) ──────────
# Dev:
CLIENT_URL=http://localhost:5173
# Production (uncomment and set your actual frontend URL):
# CLIENT_URL=https://creatokite.vercel.app

# ── Seed admin credentials ────────────────────
ADMIN_EMAIL=admin@creatokite.com
ADMIN_PASSWORD=Admin@12345

# ── Social APIs (optional) ────────────────────
YOUTUBE_API_KEY=your_youtube_api_key
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_HOST=instagram-scraper-v21.p.rapidapi.com

# ── ScrapeCreators (FREE — 100 credits, no card needed) ──────────
# Sign up: https://app.scrapecreators.com
SCRAPECREATORS_KEY=your_scrapecreators_key
